---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'projects'>['data'];

const { title, description, date, status, tags, link, github, image } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} type="article" pubDate={date} />
		<style>
			.case-study {
				width: min(720px, 100%);
				margin: 0 auto;
			}
			.header {
				margin-bottom: 2rem;
				padding: 1.5rem 1.25rem;
				border: 4px solid var(--ink);
				background:
					linear-gradient(225deg, color-mix(in srgb, var(--volt) 40%, white) 0 30%, transparent 30%),
					var(--paper);
				box-shadow: var(--shadow-hard);
				text-align: left;
			}
			.title {
				margin: 0 0 0.65rem;
				font-size: clamp(1.85rem, 4.5vw, 2.75rem);
				letter-spacing: -0.04em;
				line-height: 1.05;
			}
			.metadata {
				margin: 0 0 0.85rem;
				font-style: italic;
				color: var(--signal);
				font-size: 0.95rem;
			}
			.description {
				font-size: 1.1rem;
				line-height: 1.6;
				color: var(--muted);
				margin: 0 0 1rem;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin: 0 0 1rem;
			}
			.links {
				margin-top: 1rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}
			.content {
				margin-top: 0.5rem;
			}
			.content :global(h2) {
				font-size: clamp(1.4rem, 3vw, 1.8rem);
				margin: 2em 0 0.75em;
				padding-bottom: 0.35rem;
				border-bottom: 3px solid var(--ink);
			}
			.content :global(h3) {
				font-size: 1.25rem;
				margin: 1.5em 0 0.75em;
			}
			.content :global(p) {
				margin-bottom: 1.35em;
				line-height: 1.7;
			}
			.content :global(ul) {
				margin: 1em 0;
				padding-left: 1.25em;
			}
			.content :global(li) {
				margin: 0.45em 0;
			}
			.content :global(img) {
				border: 3px solid var(--ink);
				box-shadow: 4px 4px 0 var(--ink);
				margin: 1.5rem 0;
			}
			.status {
				display: inline-block;
				margin-bottom: 0.75rem;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="case-study">
				<header class="header">
					<div class="metadata">
						Project date <FormattedDate date={date} />
					</div>
					<span class={`tag status tag-volt`}>{status}</span>
					<h1 class="title">{title}</h1>
					<p class="description">{description}</p>
					<div class="tags">
						{tags.map((tag) => <span class="tag">{tag}</span>)}
					</div>
					<div class="links">
						{link && (
							<a href={link} class="btn" target="_blank" rel="noopener noreferrer">
								View project
							</a>
						)}
						{github && (
							<a href={github} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
								GitHub
							</a>
						)}
					</div>
				</header>
				<div class="content">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
