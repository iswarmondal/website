---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		<link rel="preload" href="/fonts/LibreBaskerville-Italic.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/LibreBaskerville-Bold.woff2" as="font" type="font/woff2" crossorigin />
		<style>
			article.newspaper {
				width: min(920px, 100%);
				margin: 0 auto;
				font-family: var(--font-article);
				font-weight: 400;
				color: var(--ink);
			}

			.masthead {
				margin-bottom: 2.75rem;
				padding-bottom: 1.75rem;
				border-bottom: 1px solid var(--line);
				text-align: left;
				animation: rise-in 0.8s ease both;
			}

			.kicker {
				display: block;
				font-family: var(--font-article);
				font-style: italic;
				font-size: 0.95rem;
				letter-spacing: 0.02em;
				color: var(--muted);
				margin-bottom: 0.85rem;
			}

			.masthead h1 {
				font-family: var(--font-display);
				font-weight: 800;
				font-size: clamp(2.1rem, 5.5vw, 3.6rem);
				letter-spacing: -0.045em;
				line-height: 0.98;
				margin: 0 0 0.9rem;
				text-transform: lowercase;
			}

			.deck {
				font-family: var(--font-article);
				font-style: italic;
				font-size: clamp(1.05rem, 2vw, 1.25rem);
				line-height: 1.55;
				margin: 0;
				color: var(--ink-soft);
				max-width: 46rem;
			}

			.byline {
				margin-top: 1.25rem;
				font-family: var(--font-article);
				font-variant: small-caps;
				font-size: 0.92rem;
				letter-spacing: 0.08em;
				color: var(--muted);
			}

			.last-updated-on {
				font-style: italic;
				font-variant: normal;
				letter-spacing: 0;
				color: var(--muted-soft);
				font-size: 0.88rem;
				margin-top: 0.55rem;
			}

			.ornament {
				display: block;
				width: 3rem;
				height: 1px;
				margin: 1.5rem 0 0;
				background: var(--ink);
				transform-origin: left;
				animation: draw-rule 0.85s 0.25s ease both;
			}

			.columns {
				font-family: var(--font-article);
				font-size: clamp(0.98rem, 0.92rem + 0.25vw, 1.08rem);
				line-height: 1.75;
				text-align: left;
				hyphens: auto;
				column-count: 2;
				column-gap: clamp(1.75rem, 4vw, 3.25rem);
				column-fill: balance;
			}

			.columns :global(p) {
				margin: 0 0 1.15em;
				orphans: 3;
				widows: 3;
			}

			.columns :global(p:first-of-type::first-letter) {
				float: left;
				font-family: var(--font-article);
				font-weight: 700;
				font-style: normal;
				font-size: 3.35em;
				line-height: 0.78;
				padding: 0.08em 0.12em 0 0;
				color: var(--ink);
			}

			.columns :global(em),
			.columns :global(i) {
				font-style: italic;
			}

			.columns :global(strong),
			.columns :global(b) {
				font-weight: 700;
			}

			.columns :global(a) {
				color: var(--ink);
				font-style: italic;
				text-decoration-thickness: 1px;
				text-underline-offset: 0.18em;
			}

			.columns :global(a:hover) {
				opacity: 0.55;
			}

			.columns :global(h2),
			.columns :global(h3),
			.columns :global(h4) {
				font-family: var(--font-article);
				font-weight: 700;
				font-style: italic;
				letter-spacing: -0.01em;
				line-height: 1.25;
				column-span: all;
				break-after: avoid;
				margin: 1.75em 0 0.85em;
				padding-top: 0.35em;
				border-top: 1px solid var(--line);
			}

			.columns :global(h2) {
				font-size: clamp(1.35rem, 2.5vw, 1.75rem);
				font-style: normal;
			}

			.columns :global(h3) {
				font-size: 1.2rem;
			}

			.columns :global(ul),
			.columns :global(ol) {
				margin: 0 0 1.15em;
				padding-left: 1.15em;
				break-inside: avoid;
			}

			.columns :global(li) {
				margin: 0.35em 0;
			}

			.columns :global(blockquote) {
				column-span: all;
				margin: 2em 0;
				padding: 1rem 1.5rem;
				border: none;
				border-top: 1px solid var(--ink);
				border-bottom: 1px solid var(--ink);
				font-style: italic;
				font-size: 1.15em;
				line-height: 1.6;
				text-align: center;
				color: var(--ink-soft);
				break-inside: avoid;
			}

			.columns :global(blockquote::before) {
				content: '“';
				display: block;
				font-size: 2.5rem;
				line-height: 1;
				margin-bottom: 0.25rem;
				font-style: normal;
			}

			.columns :global(pre),
			.columns :global(table),
			.columns :global(figure),
			.columns :global(img) {
				column-span: all;
				break-inside: avoid;
			}

			.columns :global(img) {
				margin: 1.75rem auto;
				border: none;
				filter: grayscale(100%);
			}

			.columns :global(pre) {
				margin: 1.5em 0;
			}

			.columns :global(hr) {
				column-span: all;
				margin: 2.25em 0;
				background: var(--line);
			}

			.columns :global(code) {
				font-style: normal;
			}

			.article-end {
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--line);
				display: flex;
				justify-content: flex-start;
			}

			.read-more {
				font-family: var(--font-display);
				font-weight: 800;
				font-size: 0.82rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				text-decoration: none;
				color: var(--ink);
				border-bottom: 3px solid var(--ink);
				padding-bottom: 0.2rem;
			}

			.read-more:hover {
				opacity: 0.5;
				color: var(--ink);
			}

			@media (max-width: 820px) {
				.columns {
					column-count: 1;
				}

				.columns :global(p:first-of-type::first-letter) {
					font-size: 2.85em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="newspaper">
				<header class="masthead">
					<span class="kicker">
						<FormattedDate date={pubDate} />
					</span>
					<h1>{title}</h1>
					{description && <p class="deck">{description}</p>}
					<div class="byline">By Iswar C. Mondal</div>
					{
						updatedDate && (
							<div class="last-updated-on">
								Last updated on <FormattedDate date={updatedDate} />
							</div>
						)
					}
					<span class="ornament" aria-hidden="true"></span>
				</header>
				<div class="columns">
					<slot />
				</div>
				<footer class="article-end">
					<a class="read-more" href="/blog">Read more</a>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>
