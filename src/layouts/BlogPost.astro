---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={heroImage}
			type="article"
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		<style>
			article {
				width: min(720px, 100%);
				margin: 0 auto;
			}
			.title {
				margin-bottom: 2rem;
				padding: 1.5rem 1.25rem;
				border: 4px solid var(--ink);
				background:
					linear-gradient(135deg, color-mix(in srgb, var(--sun) 55%, white) 0 35%, transparent 35%),
					var(--paper);
				box-shadow: var(--shadow-hard);
				text-align: left;
			}
			.title h1 {
				margin: 0 0 0.65rem;
				font-size: clamp(1.85rem, 4.5vw, 2.75rem);
				letter-spacing: -0.04em;
				line-height: 1.05;
			}
			.date {
				margin-bottom: 0.65rem;
				color: var(--signal);
				font-style: italic;
				font-size: 0.95rem;
			}
			.last-updated-on {
				font-style: italic;
				color: var(--muted);
				font-size: 0.9rem;
				margin-top: 0.75rem;
			}
			.description {
				font-size: 1.1rem;
				line-height: 1.6;
				margin: 0;
				color: var(--muted);
			}
			.prose {
				color: var(--ink);
			}
			.prose :global(h2),
			.prose :global(h3) {
				margin-top: 2rem;
			}
			.prose :global(a) {
				font-weight: 700;
			}
			.prose :global(img) {
				border: 3px solid var(--ink);
				box-shadow: 4px 4px 0 var(--ink);
				margin: 1.5rem 0;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<header class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
						</div>
						<h1>{title}</h1>
						{description && <p class="description">{description}</p>}
						{
							updatedDate && (
								<div class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</header>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
