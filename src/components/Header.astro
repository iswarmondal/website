---
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="site-nav" aria-label="Primary">
		<a class="brand" href="/">
			<span class="brand__mark" aria-hidden="true">◆</span>
			<span class="brand__text">iswar.me</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://twitter.com/developeriswar" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Follow on Twitter / X</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://github.com/iswarmondal" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">View GitHub profile</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: color-mix(in srgb, var(--paper) 88%, white);
		backdrop-filter: blur(8px);
		border-bottom: 3px solid var(--ink);
	}
	.site-nav {
		width: min(1100px, 100%);
		margin: 0 auto;
		padding: 0.85rem var(--site-pad);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		text-decoration: none;
		color: var(--ink);
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1.15rem;
		letter-spacing: -0.03em;
	}
	.brand:hover {
		color: var(--signal);
	}
	.brand__mark {
		color: var(--signal);
		font-size: 0.9rem;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.15rem;
	}
	.internal-links :global(a) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.95rem;
		letter-spacing: -0.01em;
		color: var(--ink);
		text-decoration: none;
		padding: 0.45rem 0.7rem;
		border: 2px solid transparent;
	}
	.internal-links :global(a:hover) {
		background: var(--sun);
		border-color: var(--ink);
		color: var(--ink);
	}
	.internal-links :global(a.active) {
		background: var(--ink);
		color: var(--paper);
		border-color: var(--ink);
		font-weight: 800;
		text-decoration: none;
	}
	.social-links {
		display: flex;
		gap: 0.35rem;
	}
	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 2px solid var(--ink);
		background: var(--paper);
		color: var(--ink);
		text-decoration: none;
	}
	.social-links a:hover {
		background: var(--cobalt);
		color: white;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.internal-links :global(a) {
			padding: 0.4rem 0.5rem;
			font-size: 0.88rem;
		}
	}
</style>
