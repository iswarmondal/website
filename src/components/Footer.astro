---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-top">
		<p class="footer-lede">Keep exploring</p>
		<nav class="footer-nav" aria-label="Footer">
			<div class="footer-col">
				<p class="footer-col__label">Site</p>
				<a href="/blog">Blog</a>
				<a href="/projects">Projects</a>
				<a href="/about">About</a>
			</div>
			<div class="footer-col">
				<p class="footer-col__label">Elsewhere</p>
				<a href="https://twitter.com/developeriswar" target="_blank" rel="noopener noreferrer">Twitter / X</a>
				<a href="https://github.com/iswarmondal" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a href="/rss.xml">RSS</a>
			</div>
		</nav>
	</div>

	<div class="footer-mega-wrap" aria-hidden="true">
		<p class="footer-mega">Iswar.me</p>
	</div>

	<div class="footer-bar">
		<a class="footer-bar__brand" href="/">◆ iswar.me</a>
		<p class="footer-bar__copy">&copy; {today.getFullYear()} Iswar C. Mondal</p>
		<nav class="footer-bar__links" aria-label="Legal">
			<a href="/about">About</a>
			<a href="/rss.xml">RSS</a>
		</nav>
	</div>
</footer>
<style>
	.site-footer {
		position: relative;
		z-index: 1;
		margin-top: 3rem;
		border-top: 3px solid var(--ink);
		background: #f7f8fb;
		color: var(--ink);
		overflow: hidden;
	}

	.footer-top {
		width: min(1100px, 100%);
		margin: 0 auto;
		padding: 2.75rem var(--site-pad) 1.5rem;
		display: grid;
		grid-template-columns: minmax(10rem, 1fr) auto;
		gap: 2rem 3rem;
		align-items: start;
	}

	.footer-lede {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(1.35rem, 2.5vw, 1.85rem);
		letter-spacing: -0.03em;
		line-height: 1.15;
		max-width: 12ch;
	}

	.footer-nav {
		display: grid;
		grid-template-columns: repeat(2, minmax(7rem, auto));
		gap: 1.5rem 3rem;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.footer-col__label {
		margin: 0 0 0.2rem;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.footer-col a {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--ink);
		text-decoration: none;
		line-height: 1.35;
	}

	.footer-col a:hover {
		color: var(--signal);
	}

	.footer-mega-wrap {
		width: 100%;
		overflow: hidden;
		line-height: 0;
		user-select: none;
		pointer-events: none;
	}

	.footer-mega {
		margin: 0;
		padding: 0;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(4.5rem, 22vw, 17rem);
		letter-spacing: -0.07em;
		line-height: 0.78;
		text-align: center;
		white-space: nowrap;
		color: var(--ink);
		transform: translateY(0.08em);
	}

	.footer-bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem 1.25rem;
		width: min(1100px, 100%);
		margin: 0 auto;
		padding: 0.9rem var(--site-pad) 1.15rem;
		border-top: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
		font-size: 0.82rem;
		color: var(--muted);
	}

	.footer-bar__brand {
		font-family: var(--font-display);
		font-weight: 800;
		color: var(--ink);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.footer-bar__brand:hover {
		color: var(--signal);
	}

	.footer-bar__copy {
		margin: 0;
	}

	.footer-bar__links {
		display: flex;
		gap: 1rem;
	}

	.footer-bar__links a {
		color: var(--muted);
		text-decoration: none;
	}

	.footer-bar__links a:hover {
		color: var(--ink);
	}

	@media (max-width: 720px) {
		.footer-top {
			grid-template-columns: 1fr;
			padding-top: 2rem;
			gap: 1.5rem;
		}

		.footer-lede {
			max-width: none;
		}

		.footer-nav {
			gap: 1.25rem 2rem;
		}

		.footer-mega {
			font-size: clamp(3.75rem, 28vw, 8rem);
			line-height: 0.8;
		}

		.footer-bar {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
