---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const projects = (await getCollection('projects'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				position: relative;
				min-height: min(78vh, 720px);
				display: grid;
				align-content: center;
				padding: 4rem 0 5rem;
				isolation: isolate;
			}
			.hero__atmosphere {
				position: absolute;
				inset: -8% -4% auto;
				height: min(70%, 28rem);
				z-index: -1;
				background:
					radial-gradient(ellipse at 30% 40%, rgba(0, 0, 0, 0.05), transparent 55%),
					radial-gradient(ellipse at 78% 20%, rgba(0, 0, 0, 0.035), transparent 45%);
				pointer-events: none;
				animation: fade-soft 1.1s ease both;
			}
			.hero__content {
				max-width: min(40rem, 100%);
			}
			.hero__brand {
				font-family: var(--font-display);
				font-weight: 800;
				font-size: clamp(3.2rem, 12vw, 6.5rem);
				letter-spacing: -0.06em;
				line-height: 0.88;
				margin: 0 0 1.5rem;
				color: var(--ink);
			}
			.hero__headline {
				font-family: var(--font-display);
				font-weight: 700;
				font-size: clamp(1.15rem, 2.4vw, 1.45rem);
				letter-spacing: -0.025em;
				line-height: 1.35;
				margin: 0 0 1rem;
				max-width: 22ch;
				color: var(--ink-soft);
			}
			.hero__headline::after {
				content: '';
				display: block;
				width: 4.5rem;
				height: 1px;
				margin-top: 1.35rem;
				background: var(--ink);
				transform-origin: left;
				animation: draw-rule 0.9s 0.35s ease both;
			}
			.hero__lede {
				margin: 0;
				color: var(--muted);
				font-size: 1.02rem;
				max-width: 34rem;
				line-height: 1.75;
			}
			.section {
				margin-top: 0.5rem;
			}
			@media (max-width: 720px) {
				.hero {
					min-height: auto;
					padding: 2.5rem 0 3rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" aria-labelledby="hero-brand">
				<div class="hero__atmosphere" aria-hidden="true"></div>
				<div class="hero__content rise">
					<p class="eyebrow">Full-stack developer</p>
					<h1 id="hero-brand" class="hero__brand">iswar.me</h1>
					<p class="hero__headline rise rise-delay-1">
						Technical writing and project case studies.
					</p>
					<p class="hero__lede rise rise-delay-2">
						I build web apps with Astro, SvelteKit, and WebRTC — and document what I learn along the way.
					</p>
					<div class="cta-row rise rise-delay-3">
						<a class="btn" href="/blog">Blog</a>
						<a class="btn btn-secondary" href="/projects">Projects</a>
					</div>
				</div>
			</section>

			<section class="section" aria-labelledby="latest-posts">
				<div class="section-head">
					<h2 id="latest-posts">Latest posts</h2>
					<a href="/blog">All articles</a>
				</div>
				<ul class="list-stack">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3 class="item-title">{post.data.title}</h3>
									<time class="item-meta" datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-us', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									{post.data.description && <p class="item-desc">{post.data.description}</p>}
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="section" aria-labelledby="featured-projects">
				<div class="section-head">
					<h2 id="featured-projects">Featured projects</h2>
					<a href="/projects">All projects</a>
				</div>
				<ul class="list-stack">
					{
						projects.map((project) => (
							<li>
								<a href={`/projects/${project.id}/`}>
									<h3 class="item-title">{project.data.title}</h3>
									<p class="item-desc">{project.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
