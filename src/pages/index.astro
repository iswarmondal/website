---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const projects = (await getCollection('projects'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				position: relative;
				min-height: min(72vh, 680px);
				display: grid;
				align-content: end;
				padding: 1.5rem 0 2rem;
				isolation: isolate;
			}
			.hero__backdrop {
				position: absolute;
				inset: 0;
				z-index: -1;
				border: 4px solid var(--ink);
				background:
					linear-gradient(135deg, rgba(198, 40, 0, 0.92) 0 38%, transparent 38%),
					linear-gradient(225deg, rgba(26, 69, 255, 0.9) 0 28%, transparent 28%),
					linear-gradient(0deg, rgba(255, 204, 0, 0.95) 0 18%, transparent 18%),
					repeating-linear-gradient(
						45deg,
						#12141a 0 10px,
						#1f2430 10px 20px
					);
				box-shadow: 8px 8px 0 var(--ink);
				overflow: hidden;
			}
			.hero__backdrop::after {
				content: 'ISWAR';
				position: absolute;
				right: -2%;
				bottom: -8%;
				font-family: var(--font-display);
				font-weight: 800;
				font-size: clamp(4rem, 18vw, 12rem);
				letter-spacing: -0.06em;
				line-height: 0.8;
				color: rgba(242, 244, 248, 0.12);
				pointer-events: none;
				user-select: none;
			}
			.hero__content {
				max-width: min(34rem, 100%);
				padding: 1.5rem;
				margin: 1.5rem;
				background: color-mix(in srgb, var(--paper) 94%, white);
				border: 4px solid var(--ink);
				box-shadow: 6px 6px 0 rgba(18, 20, 26, 0.85);
			}
			.hero__brand {
				font-family: var(--font-display);
				font-weight: 800;
				font-size: clamp(2.4rem, 8vw, 4.5rem);
				letter-spacing: -0.05em;
				line-height: 0.9;
				margin: 0 0 0.85rem;
				color: var(--ink);
			}
			.hero__brand span {
				color: var(--signal);
			}
			.hero__headline {
				font-family: var(--font-display);
				font-weight: 800;
				font-size: clamp(1.2rem, 2.8vw, 1.65rem);
				letter-spacing: -0.03em;
				line-height: 1.2;
				margin: 0 0 0.75rem;
			}
			.hero__headline::after {
				content: '';
				display: block;
				width: 100%;
				height: 5px;
				margin-top: 0.85rem;
				background: var(--ink);
				transform-origin: left;
				animation: draw-bar 0.8s 0.35s ease both;
			}
			.hero__lede {
				margin: 0;
				color: var(--muted);
				font-size: 1.05rem;
			}
			.section {
				margin-top: 1rem;
			}
			@media (max-width: 720px) {
				.hero {
					min-height: auto;
					padding: 0.75rem 0 1.25rem;
				}
				.hero__backdrop {
					box-shadow: 4px 4px 0 var(--ink);
				}
				.hero__content {
					margin: 0.85rem;
					padding: 1.1rem;
					box-shadow: 4px 4px 0 rgba(18, 20, 26, 0.85);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero" aria-labelledby="hero-brand">
				<div class="hero__backdrop" aria-hidden="true"></div>
				<div class="hero__content rise">
					<p class="eyebrow">Full-stack developer</p>
					<h1 id="hero-brand" class="hero__brand">iswar<span>.me</span></h1>
					<p class="hero__headline rise rise-delay-1">
						Technical writing and project case studies.
					</p>
					<p class="hero__lede rise rise-delay-2">
						I build web apps with Astro, SvelteKit, and WebRTC — and document what I learn along the way.
					</p>
					<div class="cta-row rise rise-delay-3">
						<a class="btn" href="/blog">Blog</a>
						<a class="btn btn-secondary" href="/projects">Projects</a>
					</div>
				</div>
			</section>

			<section class="section" aria-labelledby="latest-posts">
				<div class="section-head">
					<h2 id="latest-posts">Latest posts</h2>
					<a href="/blog">All articles →</a>
				</div>
				<ul class="list-stack">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3 class="item-title">{post.data.title}</h3>
									<time class="item-meta" datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('en-us', {
											year: 'numeric',
											month: 'short',
											day: 'numeric',
										})}
									</time>
									{post.data.description && <p class="item-desc">{post.data.description}</p>}
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="section" aria-labelledby="featured-projects">
				<div class="section-head">
					<h2 id="featured-projects">Featured projects</h2>
					<a href="/projects">All projects →</a>
				</div>
				<ul class="list-stack">
					{
						projects.map((project) => (
							<li>
								<a href={`/projects/${project.id}/`}>
									<h3 class="item-title">{project.data.title}</h3>
									<p class="item-desc">{project.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
