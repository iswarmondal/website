---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Projects"
			description="Selected projects and case studies by Iswar C. Mondal — WebRTC apps, Astro sites, AI tooling, and product experiments."
		/>
		<style>
			.page-hero {
				margin-bottom: 2.5rem;
				padding-bottom: 1.75rem;
				border-bottom: 1px solid var(--line);
				max-width: 38rem;
			}
			.page-hero h1 {
				margin-bottom: 0.65rem;
				text-transform: lowercase;
			}
			.project {
				padding: 2rem 0;
				border-bottom: 1px solid var(--line);
			}
			.project:first-of-type {
				border-top: 1px solid var(--line);
			}
			.project-top {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem 1.25rem;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 0.85rem;
			}
			.date-block {
				font-style: italic;
				color: var(--muted);
				font-size: 0.88rem;
			}
			.title {
				margin: 0 0 0.55rem;
				font-size: clamp(1.35rem, 2.5vw, 1.85rem);
			}
			.description {
				margin: 0 0 1.15rem;
				color: var(--muted);
				max-width: 40rem;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.85rem;
				margin: 0 0 1.25rem;
			}
			.read-more {
				font-family: var(--font-display);
				font-weight: 800;
				font-size: 0.78rem;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				text-decoration: none;
				color: var(--ink);
				border-bottom: 2px solid var(--ink);
				padding-bottom: 0.15rem;
			}
			.read-more:hover {
				opacity: 0.5;
				color: var(--ink);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero rise">
				<p class="eyebrow">Portfolio</p>
				<h1>My projects</h1>
				<p class="section-description" style="margin-bottom: 0;">
					Personal builds, client work, and experiments. Code for many projects stays private for security and copyright reasons.
				</p>
			</section>
			<div>
				{
					projects.map((project) => (
						<article class="project">
							<div class="project-top">
								<span class="tag">{project.data.status}</span>
								<span class="date-block">
									<FormattedDate date={project.data.date} />
								</span>
							</div>
							<h2 class="title">{project.data.title}</h2>
							<p class="description">{project.data.description}</p>
							<div class="tags">
								{project.data.tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<a href={`/projects/${project.id}/`} class="read-more">
								Read case study
							</a>
						</article>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
