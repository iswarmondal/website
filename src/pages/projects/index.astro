---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const statusClass: Record<string, string> = {
	completed: 'tag-volt',
	ongoing: 'tag-sun',
	archived: 'tag-cobalt',
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Projects"
			description="Selected projects and case studies by Iswar C. Mondal — WebRTC apps, Astro sites, AI tooling, and product experiments."
		/>
		<style>
			.page-hero {
				border: 4px solid var(--ink);
				padding: clamp(1.25rem, 4vw, 2.25rem);
				margin-bottom: 1.5rem;
				background:
					linear-gradient(270deg, var(--volt) 0 14%, transparent 14%),
					linear-gradient(0deg, color-mix(in srgb, var(--cobalt) 16%, white), var(--paper));
				box-shadow: var(--shadow-hard);
			}
			.project {
				border: 3px solid var(--ink);
				padding: 1.35rem 1.25rem 1.5rem;
				margin-bottom: 1.25rem;
				background: var(--paper);
				box-shadow: 5px 5px 0 var(--ink);
			}
			.project:nth-child(3n + 1) {
				background: color-mix(in srgb, var(--sun) 28%, white);
			}
			.project:nth-child(3n + 2) {
				background: color-mix(in srgb, var(--volt) 18%, white);
			}
			.project:nth-child(3n) {
				background: color-mix(in srgb, var(--cobalt) 12%, white);
			}
			.project-top {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 0.75rem;
			}
			.date-block {
				font-style: italic;
				color: var(--muted);
				font-size: 0.9rem;
			}
			.title {
				margin: 0 0 0.4rem;
				font-size: clamp(1.35rem, 2.5vw, 1.85rem);
			}
			.description {
				margin: 0 0 1rem;
				color: var(--muted);
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin: 0 0 1rem;
			}
			.read-more {
				font-family: var(--font-display);
				font-weight: 800;
				text-decoration: none;
				color: var(--ink);
				border-bottom: 3px solid var(--signal);
			}
			.read-more:hover {
				color: var(--signal);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero rise">
				<p class="eyebrow">Portfolio</p>
				<h1>My projects</h1>
				<p class="section-description" style="margin-bottom: 0;">
					Personal builds, client work, and experiments. Code for many projects stays private for security and copyright reasons.
				</p>
			</section>
			<div>
				{
					projects.map((project) => (
						<article class="project">
							<div class="project-top">
								<span class={`tag ${statusClass[project.data.status] ?? 'tag'}`}>
									{project.data.status}
								</span>
								<span class="date-block">
									<FormattedDate date={project.data.date} />
								</span>
							</div>
							<h2 class="title">{project.data.title}</h2>
							<p class="description">{project.data.description}</p>
							<div class="tags">
								{project.data.tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
							<a href={`/projects/${project.id}/`} class="read-more">
								Read case study →
							</a>
						</article>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
