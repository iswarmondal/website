---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Blog"
			description="Articles on Astro, SvelteKit, WebRTC, and building fast personal sites — written by Iswar C. Mondal."
		/>
		<style>
			.page-hero {
				margin-bottom: 2.5rem;
				padding-bottom: 1.75rem;
				border-bottom: 1px solid var(--line);
				max-width: 36rem;
			}
			.page-hero h1 {
				margin-bottom: 0.65rem;
				text-transform: lowercase;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero rise">
				<p class="eyebrow">Writing</p>
				<h1>Latest articles</h1>
				<p class="section-description" style="margin-bottom: 0;">
					Notes on technology, personal projects, and shipping durable web software.
				</p>
			</section>
			<ul class="list-stack">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<h2 class="item-title">{post.data.title}</h2>
								<p class="item-meta">
									<FormattedDate date={post.data.pubDate} />
								</p>
								{post.data.description && <p class="item-desc">{post.data.description}</p>}
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
